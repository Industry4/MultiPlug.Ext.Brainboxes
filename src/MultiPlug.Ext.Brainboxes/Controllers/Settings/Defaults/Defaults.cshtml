@model MultiPlug.Base.Http.EdgeApp

<form action="" method="post" accept-charset="utf-8" enctype="application/x-www-form-urlencoded">
    <section class="row-fluid">

        <div class="row-fluid">
            <div class="box">
                <div class="span3">
                    <a style="line-height: 52px;" href="#"><img alt="Brainboxes Logo" src="@Raw(Model.Context.Paths.Assets)images/brainboxes.png"></a>
                </div>
                <div class="span6">
                    <p style="font-size:26px; line-height: 54px; text-align: center; margin: 0px;">Brainboxes IO</p>
                </div>
                <div class="span3" style="text-align: right;">
                    <button type="submit" value="submit" style="height:54px; width:65px" class="item btn btn-green"><i class="icon-save icon-large"></i><p>Save</p></button>
                </div>
            </div>
        </div>

        @Include("MultiPlug.Ext.Brainboxes.BrainboxesNavigation")

        <div class="row-fluid">
            <ul class="nav nav-tabs">
                <li class="active"><a href="@Raw(Model.Context.Paths.Current)">Defaults</a></li>
            </ul>
        </div>

        <div class="row-fluid">
            <div class="box non-collapsible">
                <div class="row-fluid">

                    <div class="span4">
                        <div class="row-fluid">
                            <h5>Subject</h5>
                            <input name="Key" class="input-block-level" type="text" value="@Model.Extension.Model.Key" />
                        </div>
                    </div>

                    <div class="span4">
                        <h5>Rising Edge</h5>
                        <input name="RisingEdge" class="input-block-level" type="text" value="@Model.Extension.Model.RisingEdge" />
                    </div>

                    <div class="span4">
                        <h5>Falling Edge</h5>
                        <input name="FallingEdge" class="input-block-level" type="text" value="@Model.Extension.Model.FallingEdge" />
                    </div>

                </div>
            </div>
        </div>
    </section>
</form>