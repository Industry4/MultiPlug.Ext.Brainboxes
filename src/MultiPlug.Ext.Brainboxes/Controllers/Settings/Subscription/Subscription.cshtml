@model MultiPlug.Base.Http.EdgeApp

<form action="" method="post" accept-charset="utf-8" enctype="application/x-www-form-urlencoded">
    <section class="row-fluid">

        <div class="row-fluid">
            <div class="box">
                <div class="span3">
                    <a href="/"><img alt="Brainboxes Logo" src="@Raw(Model.Context.Paths.Assets)images/brainboxes.png"></a>
                </div>
                <div class="span6">
                    <p style="font-size:26px; line-height: 54px; text-align: center; margin: 0px;">Brainboxes IO</p>
                </div>
                <div class="span3" style="text-align: right;">
                    <button id="" type="submit" value="submit" style="height:54px; width:65px" class="item btn btn-green"><i class="icon-save icon-large"></i><p>Save</p></button>
                </div>
            </div>
        </div>

        <input type="hidden" name="DeviceId" value="@Model.Extension.Model.DeviceId">
        <input type="hidden" name="SubscriptionGuid" value="@Model.Extension.Model.SubscriptionGuid">
        <input type="hidden" name="OutputId" value="@Model.Extension.Model.OutputId">

        @Include("MultiPlug.Ext.Brainboxes.BrainboxesNavigation")

        <div class="row-fluid">
            <ul class="nav nav-tabs">
                <li class=""><a href="@Raw(Model.Context.Paths.Home)device/?id=@Model.Extension.Model.DeviceId">Device</a></li>
                <li class="active"><a href="@Raw(Model.Context.Paths.Current)">Subscription</a></li>
            </ul>
        </div>

        <div class="row-fluid">
            <div class="box non-collapsible">
                <div class="row-fluid">
                    <div class="span6">
                        <div class="row-fluid"><div class="span12">Subscription ID</div></div>
                        <div class="span12">
                            <input name="SubscriptionId" class="input-block-level mp-event-picker" type="text" value="@Model.Extension.Model.SubscriptionId" />
                        </div>
                    </div>
                    <div class="span3">
                        <div class="row-fluid"><div class="span12">HIGH Subject</div></div>
                        <div class="row-fluid"><div class="span12"><input name="HighKey" class="input-block-level" type="text" value="@Model.Extension.Model.HighKey"></div></div>
                    </div>
                    <div class="span3">
                        <div class="row-fluid"><div class="span12">HIGH Value</div></div>
                        <div class="row-fluid"><div class="span12"><input name="HighValue" class="input-block-level" type="text" value="@Model.Extension.Model.HighValue"></div></div>
                    </div>
                </div>

                <div class="row-fluid">
                    <div class="span6">
                    </div>
                    <div class="span3">
                        <div class="row-fluid"><div class="span12">LOW Subject</div></div>
                        <div class="row-fluid"><div class="span12"><input name="LowKey" class="input-block-level" type="text" value="@Model.Extension.Model.LowKey"></div></div>
                    </div>
                    <div class="span3">
                        <div class="row-fluid"><div class="span12">LOW Value</div></div>
                        <div class="row-fluid"><div class="span12"><input name="LowValue" class="input-block-level" type="text" value="@Model.Extension.Model.LowValue"></div></div>
                    </div>
                </div>
            </div>
        </div>

    </section>
</form>
